<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.gis.xian.mapper.SysTableInfoMapper">

    <resultMap id="TableInfoResultMap" type="com.gis.xian.entity.SysTableInfo">
        <result property="tableName" column="table_name" />
        <result property="tableComment" column="table_comment" />
        <result property="rowCount" column="row_count" />
        <result property="dataSize" column="data_size" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <!-- 获取所有数据库表信息 -->
    <select id="getAllTables" resultMap="TableInfoResultMap">
        SELECT
            t.table_name,
            COALESCE(d.description, '') as table_comment,
            COALESCE(s.n_live_tup, 0) as row_count,
            '0 MB' as data_size,
            tm.create_time,
            tm.update_time
        FROM information_schema.tables t
            LEFT JOIN pg_class c ON t.table_name = c.relname
            LEFT JOIN pg_description d ON c.oid = d.objoid AND d.objsubid = 0
            LEFT JOIN pg_stat_user_tables s ON t.table_name = s.relname
            LEFT JOIN table_metadata tm ON t.table_name = REPLACE(tm.table_name, 'public.', '')
        WHERE t.table_schema = 'public'
            AND t.table_type = 'BASE TABLE'
            AND t.table_name != 'spatial_ref_sys'
        ORDER BY t.table_name
    </select>

    <!-- 根据表名查询表的具体数据记录（分页） -->
    <select id="getTableData" resultType="map">
        SELECT * FROM ${tableName}
        ORDER BY id ASC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!-- 获取表的总记录数 -->
    <select id="getTableTotalCount" resultType="int">
        SELECT count(*) FROM ${tableName}
    </select>

    <!-- 获取表的字段信息 -->
    <select id="getTableColumns" resultType="map">
        SELECT
            column_name,
            data_type,
            is_nullable,
            column_default
        FROM information_schema.columns
        WHERE table_schema = 'public'
          AND table_name = #{tableName}
        ORDER BY ordinal_position
    </select>

    <!-- 修改表信息 -->
    <update id="updateTableInfo">
        <if test="newTableName != null and newTableName != ''">
            ALTER TABLE ${oldTableName} RENAME TO ${newTableName};
        </if>
        <if test="newComment != null and newComment != ''">
            COMMENT ON TABLE
            <choose>
                <when test="newTableName != null and newTableName != ''">
                    ${newTableName}
                </when>
                <otherwise>
                    ${oldTableName}
                </otherwise>
            </choose>
            IS #{newComment};
        </if>
    </update>

    <!-- 修改表数据 -->
    <update id="updateTableData">
        UPDATE ${tableName}
        <set>
            <foreach collection="updateData" item="value" index="key" separator=",">
                ${key} = #{value}
            </foreach>
        </set>
        WHERE 1=1
        <foreach collection="whereConditions" item="value" index="key">
            AND ${key} = #{value}
        </foreach>
    </update>

    <!-- 新增表数据 -->
    <insert id="insertTableData">
        INSERT INTO ${tableName}
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <foreach collection="insertData" index="key" separator=",">
                ${key}
            </foreach>
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <foreach collection="insertData" item="value" index="key" separator=",">
                #{value}
            </foreach>
        </trim>
    </insert>

    <!-- 删除表数据（物理删除） -->
    <delete id="deleteTableData">
        DELETE FROM ${tableName}
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
